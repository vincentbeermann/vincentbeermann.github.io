---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { t, altLocalePath, type Locale } from '../i18n/ui';
import profile from '../data/profile.yaml';
import Email from '../components/Email.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const pathname = Astro.url.pathname;
const altPath = altLocalePath(pathname, locale);
const canonical = new URL(pathname, Astro.site);
const links = profile.links as Record<string, string>;
const year = new Date().getFullYear();

const nav = [
  { href: locale === 'en' ? '/publications' : '/de/publications', label: t(locale, 'nav.research') },
  { href: locale === 'en' ? '/talks' : '/de/talks', label: t(locale, 'nav.speaking') },
  { href: locale === 'en' ? '/contact' : '/de/contact', label: t(locale, 'nav.contact') },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale === 'en' ? 'de' : 'en'} href={new URL(altPath, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="wordmark" href={locale === 'en' ? '/' : '/de/'}>Vincent Beermann</a>
        <nav aria-label={locale === 'en' ? 'Main navigation' : 'Hauptnavigation'}>
          {nav.map((item) => (
            <a href={item.href} aria-current={pathname.replace(/\/$/, '') === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
          <a class="lang-switch" href={altPath} rel="alternate" hreflang={locale === 'en' ? 'de' : 'en'}>
            {t(locale, 'lang.switch')}
          </a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-contact">
          <Email />
          <a href={links.linkedin} rel="me noopener">LinkedIn</a>
          <a href={links.github} rel="me noopener">GitHub</a>
        </div>
        <div class="footer-legal">
          <span>© {year} Vincent Beermann</span>
          <a href="/impressum">{t(locale, 'footer.imprint')}</a>
          <a href="/datenschutz">{t(locale, 'footer.privacy')}</a>
        </div>
      </div>
    </footer>

    <!-- Spam-Schutz: setzt E-Mail-Links aus data-Attributen zusammen,
         damit die Adresse nie als Klartext/mailto im HTML steht. -->
    <script is:inline>
      for (const a of document.querySelectorAll('a[data-eu]')) {
        const m = a.dataset.eu + '@' + a.dataset.ed;
        a.setAttribute(
          'href',
          'mailto:' + m + (a.dataset.es ? '?subject=' + encodeURIComponent(a.dataset.es) : '')
        );
        if (a.dataset.el !== undefined) a.textContent = m;
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-line);
  }

  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-m);
    padding-block: var(--space-m);
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    font-size: var(--text-small);
  }

  nav a {
    text-decoration: none;
    color: var(--color-ink-soft);
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--color-accent);
  }

  .lang-switch {
    color: var(--color-ink);
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
  }

  .lang-switch:hover {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-line);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-l);
    padding-block: var(--space-l);
    font-size: var(--text-small);
    color: var(--color-ink-soft);
  }

  .footer-contact,
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
  }

  .footer-inner a {
    color: inherit;
    text-decoration: none;
  }

  .footer-inner a:hover {
    color: var(--color-accent);
  }
</style>
