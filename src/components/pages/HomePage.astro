---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PublicationList from '../PublicationList.astro';
import ServiceCards from '../ServiceCards.astro';
import { parseLinks } from '../../lib/linkify';
import profile from '../../data/profile.yaml';
import services from '../../data/services.yaml';
import { t, type Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
/* eslint-disable @typescript-eslint/no-explicit-any */
const p = profile as any;
const s = services as any;

// Startseite zeigt alle Paper des neuesten Jahrgangs (selbstpflegend).
const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year
);
const latestYear = pubs[0]?.data.year;
const statusRank = (s?: string) =>
  s === undefined ? 0 : s === 'preprint' ? 1 : s === 'under-review' ? 2 : 3;
const current = pubs
  .filter((p) => p.data.year === latestYear)
  .sort((a, b) => statusRank(a.data.status) - statusRank(b.data.status));

const roles: string[] = p.roles.map((r: Record<string, string>) => r[locale]);

const title =
  locale === 'en'
    ? 'Vincent Beermann — Behavioral Design & AI Research'
    : 'Vincent Beermann — Behavioral Design & KI-Forschung';
const description = p.tagline[locale] + ' — ' + p.roles[0][locale];

// Tagline mit Textmarker auf dem Schlüsselwort
const tagline: string = p.tagline[locale];
const highlight: string = p.tagline_highlight[locale];
const hlIndex = tagline.indexOf(highlight);
const taglineParts =
  hlIndex >= 0
    ? {
        before: tagline.slice(0, hlIndex),
        mark: highlight,
        after: tagline.slice(hlIndex + highlight.length),
      }
    : { before: tagline, mark: '', after: '' };

const chips = ['Human-AI Interaction', 'Behavioral Design', 'Information Systems'];

// Strukturierte Daten für Suchmaschinen (Person-Schema, nur auf der Home).
const personLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vincent Beermann',
  honorificPrefix: 'Dr.',
  jobTitle:
    'Postdoctoral Researcher & Interim Chair, Design Thinking and Innovation Research',
  worksFor: {
    '@type': 'Organization',
    name: 'Hasso Plattner Institute, University of Potsdam',
  },
  url: 'https://vincentbeermann.github.io/',
  sameAs: [p.links.linkedin, p.links.github, 'https://www.menura-audio.com'],
  knowsAbout: [
    'Behavioral Design',
    'Digital Nudging',
    'Human-AI Interaction',
    'Field Experiments',
    'Information Systems',
  ],
});
---

<Base locale={locale} title={title} description={description}>
  <main>
    <section class="hero">
      <div class="container">
        <ul class="chips" aria-label={locale === 'en' ? 'Topics' : 'Themen'}>
          {chips.map((c) => <li class="chip">{c}</li>)}
        </ul>
        <h1 class="hero-tagline">
          {taglineParts.before}{taglineParts.mark && <mark>{taglineParts.mark}</mark>}{taglineParts.after}
        </h1>
        <div class="hero-sub">
          <p class="hero-name">Dr. Vincent Beermann</p>
          <ul class="hero-roles">
            {roles.map((r) => <li>{r}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="about">
      <div class="container">
        <p class="about-bio">
          {
            parseLinks(p.bio[locale]).map((part) =>
              part.href ? <a href={part.href} rel="noopener">{part.text}</a> : part.text
            )
          }
        </p>
      </div>
    </section>

    <section class="work">
      <div class="container">
        <h2 class="section-title">{t(locale, 'home.workWithMe')}</h2>
        <p class="work-intro">{s.intro[locale]}</p>
        <ServiceCards services={s.services} locale={locale} />
        <div class="work-foot">
          <a class="cta" href={locale === 'en' ? '/talks' : '/de/talks'}>
            {t(locale, 'talks.title')} →
          </a>
        </div>
      </div>
    </section>

    <section class="research">
      <div class="container">
        <h2 class="section-title">{t(locale, 'nav.research')}</h2>
        <aside class="now-card reveal">
          <p class="eyebrow">{t(locale, 'home.now')}</p>
          <p class="now-text">{p.now[locale]}</p>
        </aside>
        <PublicationList pubs={current} locale={locale} />
        <p class="section-more">
          <a href={locale === 'en' ? '/publications' : '/de/publications'}>
            {t(locale, 'home.allPublications')} →
          </a>
        </p>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={personLd} />
</Base>

<style>
  .hero {
    padding-block: var(--space-3xl) var(--space-2xl);
  }

  .chips {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .chip {
    font-family: var(--font-display);
    font-size: var(--text-small);
    font-weight: 500;
    padding: 0.25rem 0.85rem;
    border: 2px solid var(--color-line-strong);
    border-radius: 999px;
  }

  .chip:nth-child(3n + 1) {
    background: var(--tint-blue);
    transform: rotate(-1.5deg);
  }
  .chip:nth-child(3n + 2) {
    background: var(--tint-coral);
    transform: rotate(1deg);
  }
  .chip:nth-child(3n + 3) {
    background: var(--tint-yellow);
    transform: rotate(-0.5deg);
  }

  .hero-tagline {
    font-size: var(--text-hero);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    max-width: 16ch;
    margin-block: var(--space-m) var(--space-xl);
    /* Eigener Stacking-Context, damit der Marker (mark::before, z-index -1)
       hinter dem Text, aber vor dem Seitenhintergrund liegt. */
    position: relative;
    z-index: 0;
  }

  .hero-sub {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s) var(--space-2xl);
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lead);
  }

  .hero-roles {
    list-style: none;
    padding: 0;
    color: var(--color-ink-soft);
    font-size: var(--text-small);
    max-width: 34rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .about {
    border-top: 1px solid var(--color-line);
    padding-block: var(--space-2xl);
  }

  .now-card {
    max-width: 56rem;
    border: 2px solid var(--color-line-strong);
    border-radius: var(--radius);
    background: var(--tint-blue);
    padding: var(--space-l) var(--space-xl);
    transform: rotate(-0.4deg);
    margin-bottom: var(--space-xl);
  }

  .now-card .eyebrow {
    margin-bottom: var(--space-s);
  }

  .now-text {
    font-size: var(--text-lead);
    line-height: 1.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .now-card {
      transform: none;
    }
  }

  .about-bio {
    font-size: var(--text-lead);
    line-height: 1.55;
    max-width: var(--width-prose);
    text-wrap: pretty;
  }

  .section-title {
    font-size: var(--text-display);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xl);
  }

  .research,
  .work {
    border-top: 1px solid var(--color-line);
    padding-block: var(--space-2xl);
  }

  .section-more {
    margin-top: var(--space-l);
    font-family: var(--font-display);
    font-weight: 500;
  }

  .work-intro {
    font-size: var(--text-lead);
    max-width: var(--width-prose);
    margin-bottom: var(--space-xl);
  }

  .work-foot {
    margin-top: var(--space-xl);
  }

  .cta {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 600;
    text-decoration: none;
    background: var(--color-pop);
    color: var(--color-ink);
    border: 2px solid var(--color-line-strong);
    padding: 0.8rem 1.6rem;
    border-radius: 999px;
    transition:
      transform var(--duration-fast) var(--ease-bounce),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta:hover {
    color: var(--color-ink);
    transform: translateY(-3px);
    box-shadow: var(--shadow-sticker);
  }
</style>
