---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Email from '../Email.astro';
import ServiceCards from '../ServiceCards.astro';
import services from '../../data/services.yaml';
import { t, type Locale } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
/* eslint-disable @typescript-eslint/no-explicit-any */
const s = services as any;

const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title =
  locale === 'en'
    ? 'Speaking, Workshops & Coaching — Vincent Beermann'
    : 'Vorträge, Workshops & Coaching — Vincent Beermann';
const description = s.intro[locale];

const kindLabel: Record<string, { en: string; de: string }> = {
  keynote: { en: 'Keynote', de: 'Keynote' },
  talk: { en: 'Talk', de: 'Vortrag' },
  workshop: { en: 'Workshop', de: 'Workshop' },
  panel: { en: 'Panel', de: 'Panel' },
  lecture: { en: 'Lecture', de: 'Vorlesung' },
};

const mailSubject =
  locale === 'en'
    ? 'Talk / workshop / coaching enquiry'
    : 'Anfrage Vortrag / Workshop / Coaching';

const dateFmt = new Intl.DateTimeFormat(locale === 'en' ? 'en-GB' : 'de-DE', {
  year: 'numeric',
  month: 'long',
});
---

<Base locale={locale} title={title} description={description}>
  <main>
    <div class="container">
      <header class="page-head">
        <h1>{t(locale, 'talks.title')}</h1>
        <p class="lead">{s.intro[locale]}</p>
      </header>

      <ServiceCards services={s.services} locale={locale} headingLevel="h2" />

      <div class="enquiry">
        <Email
          class="cta"
          label={t(locale, 'talks.enquiry')}
          subject={mailSubject}
          fallbackHref={locale === 'en' ? '/contact' : '/de/contact'}
        />
      </div>

      <section class="past">
        <h2>{t(locale, 'talks.past')}</h2>
        <ul class="talk-list">
          {
            talks.map((talk) => (
              <li class="talk reveal">
                <span class="talk-date">{dateFmt.format(talk.data.date)}</span>
                <div>
                  <p class="talk-event">
                    {talk.data.event}
                    {talk.data.location && <span class="talk-loc"> · {talk.data.location}</span>}
                  </p>
                  <p class="talk-title">
                    {talk.data.url ? <a href={talk.data.url}>{talk.data.title}</a> : talk.data.title}
                    <span class={`talk-kind kind-${talk.data.kind}`}>
                      {kindLabel[talk.data.kind][locale]}
                    </span>
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
</Base>

<style>
  .page-head {
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .page-head h1 {
    font-size: var(--text-hero);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-m);
    max-width: 18ch;
  }

  .lead {
    font-size: var(--text-lead);
    max-width: var(--width-prose);
    color: var(--color-ink-soft);
  }

  .enquiry {
    margin-block: var(--space-xl) var(--space-2xl);
  }

  .cta {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 600;
    text-decoration: none;
    background: var(--color-pop);
    color: var(--color-ink);
    border: 2px solid var(--color-line-strong);
    padding: 0.8rem 1.6rem;
    border-radius: 999px;
    transition:
      transform var(--duration-fast) var(--ease-bounce),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta:hover {
    color: var(--color-ink);
    transform: translateY(-3px);
    box-shadow: var(--shadow-sticker);
  }

  .past {
    border-top: 1px solid var(--color-line);
    padding-block: var(--space-2xl);
  }

  .past h2 {
    font-size: var(--text-display);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xl);
  }

  .talk-list {
    list-style: none;
    padding: 0;
  }

  .talk {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-m);
    padding-block: var(--space-l);
    border-top: 1px solid var(--color-line);
  }

  .talk:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .talk-date {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-accent);
    font-size: var(--text-small);
  }

  .talk-event {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lead);
  }

  .talk-loc {
    color: var(--color-ink-soft);
    font-weight: 400;
    font-size: var(--text-body);
  }

  .talk-title {
    color: var(--color-ink-soft);
    margin-top: var(--space-2xs);
  }

  .talk-kind {
    display: inline-block;
    margin-left: var(--space-xs);
    padding: 0.1rem 0.6rem;
    border: 1.5px solid var(--color-line-strong);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: var(--text-tiny);
    font-weight: 500;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .kind-keynote {
    background: var(--tint-coral);
  }
  .kind-talk {
    background: var(--tint-blue);
  }
  .kind-workshop {
    background: var(--tint-green);
  }
  .kind-panel,
  .kind-lecture {
    background: var(--tint-yellow);
  }

  @media (max-width: 40rem) {
    .talk {
      grid-template-columns: 1fr;
      gap: var(--space-2xs);
    }
  }
</style>
