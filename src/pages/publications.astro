---
import { getCollection } from 'astro:content';

// Ungestylte Testversion — wird in M4 durch die gestaltete Seite ersetzt.
const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year
);
const published = pubs.filter((p) => !p.data.status);
const working = pubs.filter((p) => p.data.status);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Publications — Vincent Beermann</title>
  </head>
  <body>
    <main>
      <h1>Publications</h1>
      <ul>
        {
          published.map((p) => (
            <li>
              {p.data.authors.join(', ')} ({p.data.year}). <strong>{p.data.title}</strong>.
              {p.data.venue && <em> {p.data.venue}.</em>}
              {p.data.doi && <a href={`https://doi.org/${p.data.doi}`}>DOI</a>}
              {p.data.url && <a href={p.data.url}>Link</a>}
              {p.data.selected && <span> ★</span>}
            </li>
          ))
        }
      </ul>
      <h2>Under review &amp; working papers</h2>
      <ul>
        {
          working.map((p) => (
            <li>
              {p.data.authors.join(', ')} ({p.data.year}). <strong>{p.data.title}</strong>. <em>{p.data.status}</em>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
